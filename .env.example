# Internal service URLs for Docker Compose
PRODUCT_SERVICE_URL=http://product-service:8001
SEARCH_SERVICE_URL=http://search-service:8002

# Optional LLM enrichment
# LLM_ENRICHMENT_ENABLED=false: uploads use only deterministic fallback short descriptions and search text.
# LLM_ENRICHMENT_ENABLED=true: uploads also run background LLM enrichment to improve short descriptions before final enriched indexing.
LLM_ENRICHMENT_ENABLED=false
# LLM_ENRICHMENT_MODEL: model used for product short-description enrichment.
LLM_ENRICHMENT_MODEL=gpt-4o-mini
# LLM_ENRICHMENT_BASE_URL: API endpoint for the enrichment model.
LLM_ENRICHMENT_BASE_URL=https://api.openai.com/v1
# LLM_ENRICHMENT_API_KEY: credential or placeholder token for the enrichment API.
LLM_ENRICHMENT_API_KEY=
# LLM_ENRICHMENT_TIMEOUT: request timeout in seconds for one enrichment API call.
LLM_ENRICHMENT_TIMEOUT=20
# LLM_ENRICHMENT_BATCH_SIZE: maximum number of products sent in one enrichment request.
LLM_ENRICHMENT_BATCH_SIZE=8
# LLM_ENRICHMENT_MAX_BATCH_CHARS: maximum serialized payload size per enrichment request.
LLM_ENRICHMENT_MAX_BATCH_CHARS=6000
# BACKGROUND_ENRICHMENT_JOB_SIZE: number of products processed per background enrichment batch.
BACKGROUND_ENRICHMENT_JOB_SIZE=4

# Optional shared OpenAI-compatible aliases
# MODEL: default model name used as a fallback by enrichment/query-parser settings.
MODEL=
# BASE_URL: OpenAI-compatible API endpoint, e.g. https://api.openai.com/v1 or http://host.docker.internal:11434/v1
BASE_URL=
# API_KEY: credential or placeholder token used by the target compatible API.
API_KEY=

# Optional LLM query parsing for search
# QUERY_PARSER_LLM_ENABLED=false: search uses the built-in rule-based parser for filters and intent.
# QUERY_PARSER_LLM_ENABLED=true: search sends the user query to an LLM parser before hybrid retrieval.
QUERY_PARSER_LLM_ENABLED=false
# QUERY_PARSER_LLM_MODEL: model used to convert natural language queries into structured search filters.
QUERY_PARSER_LLM_MODEL=gpt-4o-mini
# QUERY_PARSER_LLM_BASE_URL: API endpoint for the query parser model.
QUERY_PARSER_LLM_BASE_URL=
# QUERY_PARSER_LLM_API_KEY: credential or placeholder token for the query parser API.
QUERY_PARSER_LLM_API_KEY=
# QUERY_PARSER_LLM_TIMEOUT: request timeout in seconds for one query parsing call.
QUERY_PARSER_LLM_TIMEOUT=15
